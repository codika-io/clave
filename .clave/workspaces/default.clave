{
  "$schema": "clave/1.0",
  "name": "Clave",
  "cwd": "..",
  "category": "Products",
  "color": "blue",
  "logo": "data:image/svg+xml;base64,",
  "sessions": [
    {
      "cwd": "..",
      "name": "Clave",
      "claudeMode": true,
      "geminiMode": false,
      "codexMode": false,
      "dangerousMode": true
    }
  ],
  "terminals": [
    {
      "command": "npm run dev",
      "commandMode": "auto",
      "cwd": ".",
      "color": "green",
      "icon": "bolt",
      "autoLaunchLocalhost": true
    }
  ]
}
